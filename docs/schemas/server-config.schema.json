{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openharness.dev/schemas/server-config.schema.json",
  "title": "OpenAgentHarness Server Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "server": {
      "type": "object",
      "required": [
        "host",
        "port"
      ],
      "additionalProperties": false,
      "properties": {
        "host": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "postgres_url": {
          "type": "string"
        },
        "redis_url": {
          "type": "string"
        }
      }
    },
    "object_storage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "bucket",
        "region"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "enum": [
            "s3"
          ]
        },
        "bucket": {
          "type": "string",
          "minLength": 1
        },
        "region": {
          "type": "string",
          "minLength": 1
        },
        "endpoint": {
          "type": "string",
          "minLength": 1
        },
        "access_key": {
          "type": "string",
          "minLength": 1
        },
        "secret_key": {
          "type": "string",
          "minLength": 1
        },
        "session_token": {
          "type": "string",
          "minLength": 1
        },
        "force_path_style": {
          "type": "boolean"
        },
        "sync_on_boot": {
          "type": "boolean"
        },
        "sync_on_change": {
          "type": "boolean"
        },
        "poll_interval_ms": {
          "type": "integer",
          "minimum": 1000
        },
        "managed_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "workspace",
              "chat",
              "template",
              "model",
              "tool",
              "skill",
              "archive"
            ]
          },
          "uniqueItems": true
        },
        "key_prefixes": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "workspace": {
              "type": "string"
            },
            "chat": {
              "type": "string"
            },
            "template": {
              "type": "string"
            },
            "model": {
              "type": "string"
            },
            "tool": {
              "type": "string"
            },
            "skill": {
              "type": "string"
            },
            "archive": {
              "type": "string"
            }
          }
        }
      }
    },
    "paths": {
      "type": "object",
      "required": [
        "workspace_dir",
        "chat_dir",
        "template_dir",
        "model_dir",
        "tool_dir",
        "skill_dir"
      ],
      "additionalProperties": false,
      "properties": {
        "workspace_dir": {
          "type": "string"
        },
        "chat_dir": {
          "type": "string"
        },
        "template_dir": {
          "type": "string"
        },
        "model_dir": {
          "type": "string",
          "description": "Preferred path for platform models."
        },
        "tool_dir": {
          "type": "string",
          "description": "Preferred path for platform external tools."
        },
        "skill_dir": {
          "type": "string"
        },
        "archive_dir": {
          "type": "string",
          "description": "Optional path for exported archive SQLite bundles."
        }
      }
    },
    "llm": {
      "type": "object",
      "required": [
        "default_model"
      ],
      "additionalProperties": false,
      "properties": {
        "default_model": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
