{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openharness.dev/schemas/server-config.schema.json",
  "title": "OpenAgentHarness Server Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "server": {
      "type": "object",
      "required": [
        "host",
        "port"
      ],
      "additionalProperties": false,
      "properties": {
        "host": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "postgres_url": {
          "type": "string"
        },
        "redis_url": {
          "type": "string"
        }
      }
    },
    "paths": {
      "type": "object",
      "required": [
        "workspace_dir",
        "chat_dir",
        "template_dir",
        "skill_dir"
      ],
      "additionalProperties": false,
      "allOf": [
        {
          "anyOf": [
            {
              "required": [
                "model_dir"
              ]
            },
            {
              "required": [
                "models_dir"
              ]
            }
          ]
        },
        {
          "anyOf": [
            {
              "required": [
                "tool_dir"
              ]
            },
            {
              "required": [
                "mcp_dir"
              ]
            }
          ]
        }
      ],
      "properties": {
        "workspace_dir": {
          "type": "string"
        },
        "chat_dir": {
          "type": "string"
        },
        "template_dir": {
          "type": "string"
        },
        "model_dir": {
          "type": "string",
          "description": "Preferred path for platform models."
        },
        "models_dir": {
          "type": "string",
          "description": "Deprecated legacy alias for model_dir.",
          "deprecated": true
        },
        "tool_dir": {
          "type": "string",
          "description": "Preferred path for platform external tools."
        },
        "mcp_dir": {
          "type": "string",
          "description": "Deprecated legacy alias for tool_dir.",
          "deprecated": true
        },
        "skill_dir": {
          "type": "string"
        }
      }
    },
    "llm": {
      "type": "object",
      "required": [
        "default_model"
      ],
      "additionalProperties": false,
      "properties": {
        "default_model": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
